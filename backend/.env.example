# ─── Anthropic ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Firebase / Firestore ──────────────────────
# Pega aquí el JSON COMPLETO de la cuenta de servicio, en una sola línea.
# Se obtiene en: Firebase Console -> ⚙️ Configuración del proyecto ->
# Cuentas de servicio -> Generar nueva clave privada (descarga un .json).
# NUNCA subas ese .json al repositorio; esta variable de entorno es el
# único lugar donde debe vivir.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"tu-proyecto",...}

# ─── Clerk ────────────────────────────────────
CLERK_ISSUER_URL=https://discrete-reptile-59.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=whsec_change_me

# ─── YouTube Data API (opcional, mejora metadata/duración) ──
# Sin esta key, el sistema cae automáticamente a oEmbed (sin duración exacta).
YOUTUBE_DATA_API_KEY=

# ─── Transcripción: fallback con Whisper local ────
# Si youtube-transcript-api falla (bloqueo de IP, video sin subtítulos),
# se intenta transcribir el audio localmente con faster-whisper.
# No requiere ninguna API externa, pero usa CPU/RAM del propio servidor.
ENABLE_WHISPER_FALLBACK=true
WHISPER_MODEL_SIZE=base   # tiny|base|small|medium (más grande = más preciso y más lento)

# ─── Stripe ───────────────────────────────────
# Sin plan gratis: todo usuario empieza en "trial" (3 resúmenes de cortesía)
# y debe suscribirse a Starter o Pro para seguir usando el servicio.
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRODUCT_STARTER=prod_UiLxrL4q3jo0d5
STRIPE_PRODUCT_PRO=prod_UiLxoqpYqemCDN

# ─── App ──────────────────────────────────────
ENVIRONMENT=production
CORS_ORIGINS=https://resumidorai.vercel.app,http://localhost:3000
FRONTEND_URL=https://resumidorai.vercel.app
